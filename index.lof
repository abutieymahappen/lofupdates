<!-- SETTINGS Popup -->
<div id="settingsPopup" class="file-modal">
  <div class="file-content">
    <h3>⚙️ SETTINGS</h3>
    <p class="warning">CUSTOMIZE LOF v2.1</p>
    <h4>🎨 APPEARANCE</h4>
    <div class="file-row">
      <div class="file-row-top">
        <button class="file-name">Dark Mode</button>
        <button id="themeToggle" class="download-btn" onclick="toggleTheme()">ON</button>
      </div>
    </div>
    <h4>🎨 ACCENT COLOR</h4>
<div class="file-row">
  <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:10px;width:100%">
    <button onclick="setAccent('#00f2ff')" style="height:45px;border-radius:12px;border:2px solid #222;background:#00f2ff;cursor:pointer"></button>
    <button onclick="setAccent('#00ff88')" style="height:45px;border-radius:12px;border:2px solid #222;background:#00ff88;cursor:pointer"></button>
    <button onclick="setAccent('#ff00ff')" style="height:45px;border-radius:12px;border:2px solid #222;background:#ff00ff;cursor:pointer"></button>
    <button onclick="setAccent('#ff9500')" style="height:45px;border-radius:12px;border:2px solid #222;background:#ff9500;cursor:pointer"></button>
    <button onclick="setAccent('#ff3333')" style="height:45px;border-radius:12px;border:2px solid #222;background:#ff3333;cursor:pointer"></button>
    <button onclick="setAccent('#8a2be2')" style="height:45px;border-radius:12px;border:2px solid #222;background:#8a2be2;cursor:pointer"></button>
  </div>
</div>
    <h4>📳 HAPTICS</h4>
    <div class="file-row">
      <div class="file-row-top">
        <button class="file-name">Tile Vibration</button>
        <button id="hapticToggle" class="download-btn" onclick="toggleHaptic()">ON</button>
      </div>
    </div>
    <h4>🗑️ DATA</h4>
    <div class="file-row">
      <div class="file-row-top">
        <button class="file-name">Reset All Ratings</button>
        <button class="download-btn" style="background:linear-gradient(135deg,#ff3333,#ff0066)" onclick="resetRatings()">CLEAR</button>
      </div>
    </div>
    <button class="close-popup" onclick="closeSettings()">CLOSE</button>
  </div>
</div>

<!-- CUSTOM UPDATE POPUP -->
<div id="updatePopup" class="file-modal">
  <div class="file-content">
    <h3>🔄 UPDATE AVAILABLE</h3>
    <p class="warning" id="updateVersion">v2.1</p>
    <h4>📋 WHAT'S NEW</h4>
    <p id="updateChangelog" style="color:#aaa;font-size:14px;line-height:1.6;text-align:center;margin:15px 0;">
      New configs + bug fixes
    </p>
    <div style="display:flex;gap:12px;margin-top:25px">
      <button id="laterBtn" class="close-popup" style="flex:1;background:#222;color:#aaa;border:1px solid #333" onclick="closeUpdatePopup()">LATER</button>
      <button class="download-btn" style="flex:1" onclick="downloadUpdate()">DOWNLOAD</button>
    </div>
  </div>
</div>

<script>
// === UPDATE SYSTEM CONFIG ===
const CURRENT_VERSION = "2.1"; 
const CURRENT_VERSION_CODE = 3; // v2.1
const UPDATE_API_URL = "https://raw.githubusercontent.com/abutieymahappen/lofupdates/main/version.json";
let updateData = null;

window.onload=()=>{
setTimeout(()=>{document.getElementById("loader").style.display="none";},1200);
checkUpdate(); // UPDATE CHECKER
loadRatings();
loadTheme();

// Apply accent on load
const accentColor = localStorage.getItem('lof_accent') || '#00f2ff';
document.documentElement.style.setProperty('--accent', accentColor);
document.documentElement.style.setProperty('--accent-glow', hexToRgba(accentColor, 0.3));
document.documentElement.style.setProperty('--accent-dark', hexToRgba(accentColor, 0.1));

/* APP-STYLE TAP EFFECT FOR TILES */
document.querySelectorAll('.tool-card').forEach(tile => {
  const pressIn = () => {
    tile.style.transform = 'scale(0.97)';
    tile.style.opacity = '0.85';
    if (hapticEnabled && navigator.vibrate) navigator.vibrate(8);
  };
  const pressOut = () => {
    tile.style.transform = 'scale(1)';
    tile.style.opacity = '1';
  };
  tile.addEventListener('touchstart', pressIn, {passive:true});
  tile.addEventListener('touchend', pressOut);
  tile.addEventListener('touchcancel', pressOut);
  tile.addEventListener('mousedown', pressIn);
  tile.addEventListener('mouseup', pressOut);
  tile.addEventListener('mouseleave', pressOut);
});
};

function toggleMenu(){
document.getElementById("sidebar").classList.toggle("active");
document.getElementById("overlay").classList.toggle("active");
}

function showPage(pageId){
const pages=["home-page","about-page","contact-page","announcements-page"];
pages.forEach(id=>{document.getElementById(id).style.display="none";});
document.getElementById(pageId).style.display="block";
toggleMenu();
}

function showHcPopup() {document.getElementById('hcPopup').style.display = 'flex'; loadRatings();}
function closeHcPopup() {document.getElementById('hcPopup').style.display = 'none';}
function showHatPopup() {document.getElementById('hatPopup').style.display = 'flex'; loadRatings();}
function closeHatPopup() {document.getElementById('hatPopup').style.display = 'none';}
function showTlsPopup() {document.getElementById('tlsPopup').style.display = 'flex'; loadRatings();}
function closeTlsPopup() {document.getElementById('tlsPopup').style.display = 'none';}
function showNpvtPopup() {document.getElementById('npvtPopup').style.display = 'flex'; loadRatings();}
function closeNpvtPopup() {document.getElementById('npvtPopup').style.display = 'none';}
function showSettings() {
  document.getElementById('settingsPopup').style.display = 'flex';
  document.getElementById('hapticToggle').innerText = hapticEnabled? 'ON' : 'OFF';
  document.getElementById('themeToggle').innerText = darkMode? 'ON' : 'OFF';
  toggleMenu();
}
function closeSettings() {
  document.getElementById('settingsPopup').style.display = 'none';
}

document.querySelectorAll('.file-modal').forEach(modal => {
  modal.addEventListener('click', function(e) {
    if(e.target === this) this.style.display = 'none';
  });
});

// RATING SYSTEM
function loadRatings(){
  document.querySelectorAll('.stars').forEach(starBox=>{
    const fileId = starBox.dataset.file;
    if(!fileId) return;
    const saved = JSON.parse(localStorage.getItem('lof_ratings') || '{}');
    const rating = saved[fileId] || 0;
    updateStars(starBox, rating);
    starBox.querySelectorAll('.star').forEach((star, i)=>{
      star.onclick = ()=>{
        const newRating = i+1;
        saved[fileId] = newRating;
        localStorage.setItem('lof_ratings', JSON.stringify(saved));
        updateStars(starBox, newRating);
        showToast(`Rated ${newRating}★`);
      }
    });
  });
}
function updateStars(starBox, rating){
  const stars = starBox.querySelectorAll('.star');
  stars.forEach((s, i)=> s.classList.toggle('active', i < rating));
  const countEl = starBox.parentElement.querySelector('.rating-count');
  if(countEl) countEl.textContent = rating > 0? rating+'★' : '0';
}
function showToast(msg) {
  const toast = document.getElementById('toast');
  toast.innerText = msg;
  toast.style.display = 'block';
  setTimeout(() => { toast.style.display = 'none'; }, 1200);
}

let hapticEnabled = localStorage.getItem('lof_haptic')!== 'false';
let darkMode = localStorage.getItem('lof_theme')!== 'light';

function toggleHaptic() {
  hapticEnabled =!hapticEnabled;
  localStorage.setItem('lof_haptic', hapticEnabled);
  document.getElementById('hapticToggle').innerText = hapticEnabled? 'ON' : 'OFF';
  showToast(hapticEnabled? 'Haptics ON' : 'Haptics OFF');
}

function toggleTheme() {
  darkMode =!darkMode;
  localStorage.setItem('lof_theme', darkMode? 'dark' : 'light');
  document.body.style.background = darkMode? '#050505' : '#f0f0f0';
  document.body.style.color = darkMode? '#e0e0e0' : '#111';
  document.getElementById('themeToggle').innerText = darkMode? 'ON' : 'OFF';
  showToast(darkMode? 'Dark Mode ON' : 'Light Mode ON');
}

function loadTheme() {
  const saved = localStorage.getItem('lof_theme') || 'dark';
  darkMode = saved === 'dark';
  document.body.style.background = darkMode? '#050505' : '#f0f0f0';
  document.body.style.color = darkMode? '#e0e0e0' : '#111';
}

function resetRatings() {
  localStorage.removeItem('lof_ratings');
  showToast('Ratings cleared!');
  setTimeout(() => location.reload(), 800);
}

function setAccent(color) {
  localStorage.setItem('lof_accent', color);
  document.documentElement.style.setProperty('--accent', color);
  document.documentElement.style.setProperty('--accent-glow', hexToRgba(color, 0.3));
  document.documentElement.style.setProperty('--accent-dark', hexToRgba(color, 0.1));
  showToast('Color updated!');
}

function hexToRgba(hex, alpha) {
  const r = parseInt(hex.slice(1,3), 16);
  const g = parseInt(hex.slice(3,5), 16);
  const b = parseInt(hex.slice(5,7), 16);
  return `rgba(${r},${g},${b},${alpha})`;
}

// AUTO DOWNLOAD FOR CONFIG FILES + APK
function autoDownload(url, filename) {
  showToast('Opening browser...');
  
  // Skip WebView download manager completely
  setTimeout(() => {
    if(typeof Android !== 'undefined' && Android.openURL) {
      Android.openURL(url); // Web2APK method
    } else if(typeof web2apk !== 'undefined') {
      web2apk.openExternal(url); // WebToApp method
    } else {
      window.open(url, '_system'); // Cordova/others
    }
  }, 300);
}

// CUSTOM UPDATE CHECKER - NO COUNTDOWN
async function checkUpdate() {
  try {
    const res = await fetch(UPDATE_API_URL + '?t=' + Date.now(), {cache: 'no-store'});
    if(!res.ok) throw new Error('Network error');
    const data = await res.json();

    if (data.version_code > CURRENT_VERSION_CODE) {
      updateData = data;
      document.getElementById('updateVersion').innerText = 'v' + data.version;
      document.getElementById('updateChangelog').innerText = data.changelog;
      document.getElementById('updatePopup').style.display = 'flex';

      if (data.force_update === true) {
        document.getElementById('laterBtn').style.display = 'none';
      } else {
        document.getElementById('laterBtn').style.display = 'block';
      }
    } else {
      console.log("App is up to date v" + CURRENT_VERSION);
    }
  } catch(e) {
    console.log("Update check failed:", e.message);
  }
}

function closeUpdatePopup() {
  document.getElementById('updatePopup').style.display = 'none';
}

function downloadUpdate() {
  if(updateData) {
    closeUpdatePopup();
    showToast('Opening browser...');
    setTimeout(() => {
      window.open(updateData.update_url, '_system');
    }, 300);
  }
}
function toggleMenu(){
  document.getElementById('sidebar').classList.toggle('active');
  document.getElementById('overlay').classList.toggle('active');
}
function showPage(id){
  document.querySelectorAll('body > div[id$="-page"]').forEach(p=>p.style.display='none');
  document.getElementById(id).style.display='block';
  toggleMenu(); // closes sidebar after clicking
}
</script></body>
</html>
