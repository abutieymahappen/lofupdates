<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BROSKIEX v2.1</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Rajdhani',sans-serif;}
:root{--accent:#00f2ff;--accent-glow:rgba(0,242,255,0.3);--accent-dark:rgba(0,242,255,0.1);}
body{background:#050505;color:#e0e0e0;padding:20px;background-image:radial-gradient(circle at 30% 30%, var(--accent-dark) 0%, transparent 60%);}
#loader{position:fixed;inset:0;background:#050505;display:flex;justify-content:center;align-items:center;font-size:2.8rem;font-weight:900;font-family:'Orbitron',sans-serif;color:var(--accent);z-index:9999;letter-spacing:5px;text-shadow:0 0 20px var(--accent-glow);animation:pulse 1.5s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.6}}
.header{display:flex;justify-content:space-between;align-items:center;margin-bottom:35px;}
.logo{fauont-size:1.8rem;font-weight:900;font-family:'Orbitron',sans-serif;background:linear-gradient(90deg,var(--accent),#00ffea);-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:2px;text-shadow:0 0 15px var(--accent-dark);}
.section-title{color:var(--accent);margin:30px 0 18px;font-size:1.2rem;font-weight:700;font-family:'Orbitron',sans-serif;letter-spacing:2px;text-transform:uppercase;}
.tool-card{display:flex;justify-content:space-between;align-items:center;background:linear-gradient(135deg,#121212,#080808);padding:22px;border-radius:18px;margin-bottom:18px;border:1px solid #1f1f1f;transition: transform 0.08s ease, opacity 0.08s ease, border-color 0.3s, box-shadow 0.3s;cursor:pointer;box-shadow:0 0 0px rgba(0,242,255,0);-webkit-tap-highlight-color: transparent;touch-action: manipulation;user-select: none;}
.tool-card:hover{border-color:var(--accent);transform:translateY(-4px);box-shadow:0 0 25px var(--accent-glow);}
.tool-card:active{border-color:var(--accent);box-shadow:0 0 15px var(--accent-dark);}
.tool-left h3{font-size:18px;margin-bottom:6px;font-weight:700;font-family:'Orbitron',sans-serif;letter-spacing:1px;}
.tool-left p{font-size:13px;color:#888;font-weight:600;}
.arrow{font-size:32px;color:var(--accent);font-weight:300;text-shadow:0 0 10px var(--accent-glow);}
.banner{background:linear-gradient(135deg,var(--accent-dark),#0a0a0a);padding:28px;border-radius:22px;margin-bottom:35px;border:1px solid var(--accent-glow);position:relative;overflow:hidden;text-align:center;}
.banner::before{content:'';position:absolute;top:-50%;right:-50%;width:250px;height:250px;background:radial-gradient(circle,var(--accent-dark),transparent);border-radius:50%;animation:spin 20s linear infinite;}
@keyframes spin{100%{transform:rotate(360deg)}}
.banner h2{color:var(--accent);margin-bottom:6px;font-size:1.4rem;font-family:'Orbitron',sans-serif;letter-spacing:1.5px;}
.banner p{color:#aaa;font-size:14px;font-weight:600;position:relative;margin-top:6px;}
.menu-btn{font-size:32px;color:var(--accent);cursor:pointer;font-weight:700;-webkit-tap-highlight-color: transparent;}
.sidebar{position:fixed;top:0;left:-280px;width:270px;height:100%;background:#070707;padding-top:80px;transition:.4s;z-index:999;border-right:1px solid var(--accent-dark);}
.sidebar.active{left:0;}
.sidebar a{display:block;padding:20px 30px;color:#ddd;text-decoration:none;border-bottom:1px solid #151515;font-weight:600;font-size:15px;transition:.3s;letter-spacing:1px;-webkit-tap-highlight-color: transparent;}
.sidebar a:hover{background:#111;color:var(--accent);padding-left:38px;text-shadow:0 0 8px var(--accent-glow);}
.overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.8);display:none;z-index:998;backdrop-filter:blur(6px);}
.overlay.active{display:block;}
.back-btn{margin-top:25px;padding:15px 26px;background:#0a0a0a;border:1px solid var(--accent);border-radius:12px;color:var(--accent);cursor:pointer;font-size:14px;font-weight:700;font-family:'Orbitron',sans-serif;letter-spacing:1px;transition:.3s;-webkit-tap-highlight-color: transparent;}
.back-btn:hover{background:var(--accent-dark);box-shadow:0 0 15px var(--accent-glow);}
.back-btn:active{transform:scale(0.97);opacity:0.85;}
.file-modal{display:none;position:fixed;z-index:10000;left:0;top:0;width:100%;height:100%;background:rgba(0,0,0,0.95);justify-content:center;align-items:center;padding:20px;backdrop-filter:blur(12px);}
.file-content{background:linear-gradient(135deg,#0f0f0f,#050505);padding:32px;border-radius:22px;border:1px solid var(--accent-glow);width:100%;max-width:460px;color:#FFF;max-height:85vh;overflow-y:auto;box-shadow:0 0 40px var(--accent-glow);}
.file-content h3{color:var(--accent);margin:0 0 12px 0;text-align:center;font-size:24px;font-weight:900;font-family:'Orbitron',sans-serif;letter-spacing:2px;text-shadow:0 0 12px var(--accent-glow);}
.file-content h4{color:var(--accent);font-size:15px;margin:22px 0 12px 0;font-weight:700;font-family:'Orbitron',sans-serif;border-bottom:2px solid #1a1a1a;padding-bottom:8px;letter-spacing:1px;}
.warning{color:#ff4d4d;text-align:center;font-size:13px;margin-bottom:22px;font-weight:700;letter-spacing:1px;}
.file-row{display:flex;flex-direction:column;gap:8px;margin:12px 0;padding-bottom:18px;border-bottom:1px solid #151515;}
.file-row-top{display:flex;gap:12px;align-items:center;}
.file-name{flex:1;background:#070707;border:1px solid #222;color:#00ffcc;padding:16px;border-radius:12px;text-align:left;font-family:'Orbitron',monospace;font-size:16px;font-weight:700;letter-spacing:1px;-webkit-tap-highlight-color: transparent;}
.download-btn{background:linear-gradient(135deg,var(--accent),#00d4ff);border:none;color:#000;padding:16px 20px;border-radius:12px;font-size:13px;font-weight:900;font-family:'Orbitron',sans-serif;cursor:pointer;white-space:nowrap;transition:.3s;letter-spacing:1px;box-shadow:0 0 15px var(--accent-glow);text-decoration:none;-webkit-tap-highlight-color: transparent;}
.download-btn:hover{transform:scale(1.05);box-shadow:0 0 25px var(--accent-glow);}
.download-btn:active{transform:scale(0.96);opacity:0.9;}
.close-popup{margin-top:25px;width:100%;padding:17px;background:linear-gradient(135deg,var(--accent),#00d4ff);border:none;border-radius:14px;color:#000;cursor:pointer;font-weight:900;font-size:15px;font-family:'Orbitron',sans-serif;letter-spacing:1.5px;transition:.3s;-webkit-tap-highlight-color: transparent;}
.close-popup:hover{box-shadow:0 0 25px var(--accent-glow);transform:scale(1.02);}
.close-popup:active{transform:scale(0.98);opacity:0.9;}
.toast{position:fixed;bottom:40px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,var(--accent),#00d4ff);color:#000;padding:14px 28px;border-radius:12px;display:none;font-weight:800;z-index:10001;font-size:14px;font-family:'Orbitron',sans-serif;box-shadow:0 0 30px var(--accent-glow);letter-spacing:1px;}
.rating-box{display:flex;align-items:center;gap:10px;margin-top:6px;}
.rating-label{font-size:12px;color:#777;font-weight:600;}
.stars{display:flex;gap:5px;}
.star{font-size:22px;color:#2a2a2a;cursor:pointer;transition:0.2s;user-select:none;-webkit-tap-highlight-color: transparent;}
.star:hover,.star.active{color:var(--accent);transform:scale(1.25);text-shadow:0 0 10px var(--accent-glow);}
.rating-count{font-size:11px;color:#555;margin-left:5px;font-weight:700;}
.channel-btn{display:inline-block;margin-top:15px;padding:14px 28px;background:linear-gradient(135deg,#ff3333,#ff0066);color:#fff;text-decoration:none;border-radius:12px;font-weight:900;font-family:'Orbitron',sans-serif;letter-spacing:1.5px;box-shadow:0 0 20px #ff333360;transition:.3s;-webkit-tap-highlight-color: transparent;}
.channel-btn:hover{transform:scale(1.05);box-shadow:0 0 30px #ff006680;}
.channel-btn:active{transform:scale(0.98);opacity:0.9;}
</style></head>
<body>

<div id="loader">LOF v2.1</div>

